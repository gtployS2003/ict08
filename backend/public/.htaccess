<IfModule LiteSpeed>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^/backend/public/line_webhook.php$
    RewriteRule .* - [E=LSAPI_NO_BUFFERING:1]
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 🚨🚨🚨 DO NOT REWRITE LINE WEBHOOK
    RewriteCond %{REQUEST_URI} ^/backend/public/line_webhook\.php$
    RewriteRule ^ - [L]

    # 🚨 DO NOT REWRITE special endpoints
    RewriteCond %{REQUEST_URI} ^/backend/public/(api-|test_post|line_webhook_debug|line_webhook_detailed|line_webhook_test|line_webhook_simple)
    RewriteRule ^ - [L]

    # pass Authorization header to PHP
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # handle CORS preflight (ให้ PHP ส่ง CORS headers + 204)
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^ index.php [QSA,L]

    # skip real files/folders
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # route to index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>